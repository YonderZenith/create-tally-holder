# Tally holder configuration
# Generated by `npx create-tally-holder` — customize as needed.

# The Tally relay this holder registers with.
TALLY_RELAY_URL=https://api.tally.qisprotocol.com

# Display name for this node (shown in relay listings, logs).
TALLY_NODE_NAME=tally-holder

# Unique node identifier (auto-generated, must be stable across restarts).
TALLY_NODE_ID=tally-holder-abcdef

# Your agent_id = sha256(public_key).slice(0, 16) — derived from data/identity.json.
TALLY_AGENT_ID=

# Local data directory — SQLite DB + identity live here.
TALLY_DATA_DIR=./data

# Port for inbound HTTP server. Only started if TALLY_PUBLIC_URL is set.
TALLY_LISTEN_PORT=7894

# Public URL of this holder (e.g. https://holder.example.com).
# LEAVE BLANK for outbound-only mode — you'll still pull packets every 15m
# and participate in the partition table, but you won't receive real-time pushes.
TALLY_PUBLIC_URL=

# Path to identity file (keypair). Do NOT share this file — it's your node's signing key.
TALLY_IDENTITY_PATH=./data/identity.json
